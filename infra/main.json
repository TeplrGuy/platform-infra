{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "5896032364798505549"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "westeurope",
      "metadata": {
        "description": "Primary deployment location"
      }
    },
    "environmentName": {
      "type": "string",
      "metadata": {
        "description": "Environment name (dev/test/prod)"
      }
    },
    "prefix": {
      "type": "string",
      "metadata": {
        "description": "Resource name prefix, lowercase, no spaces"
      }
    }
  },
  "variables": {
    "rgName": "[format('{0}-{1}-rg', parameters('prefix'), parameters('environmentName'))]",
    "logAnalyticsName": "[format('{0}-{1}-law', parameters('prefix'), parameters('environmentName'))]",
    "appInsightsName": "[format('{0}-{1}-appi', parameters('prefix'), parameters('environmentName'))]",
    "keyVaultName": "[toLower(format('{0}{1}kv', take(parameters('prefix'), 12), parameters('environmentName')))]",
    "serviceBusNamespaceName": "[toLower(format('{0}{1}bus', take(parameters('prefix'), 18), parameters('environmentName')))]",
    "containerAppsEnvironmentName": "[format('{0}-{1}-cae', parameters('prefix'), parameters('environmentName'))]",
    "containerRegistryName": "[toLower(replace(format('{0}{1}acr', take(parameters('prefix'), 10), parameters('environmentName')), '-', ''))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2024-03-01",
      "name": "[variables('rgName')]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "platform-resources",
      "resourceGroup": "[variables('rgName')]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "prefix": {
            "value": "[parameters('prefix')]"
          },
          "environmentName": {
            "value": "[parameters('environmentName')]"
          },
          "logAnalyticsName": {
            "value": "[variables('logAnalyticsName')]"
          },
          "appInsightsName": {
            "value": "[variables('appInsightsName')]"
          },
          "keyVaultName": {
            "value": "[variables('keyVaultName')]"
          },
          "serviceBusNamespaceName": {
            "value": "[variables('serviceBusNamespaceName')]"
          },
          "containerAppsEnvironmentName": {
            "value": "[variables('containerAppsEnvironmentName')]"
          },
          "containerRegistryName": {
            "value": "[variables('containerRegistryName')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "8815937719152971417"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Primary deployment location"
              }
            },
            "prefix": {
              "type": "string",
              "metadata": {
                "description": "Resource name prefix"
              }
            },
            "environmentName": {
              "type": "string",
              "metadata": {
                "description": "Environment name"
              }
            },
            "logAnalyticsName": {
              "type": "string"
            },
            "appInsightsName": {
              "type": "string"
            },
            "keyVaultName": {
              "type": "string"
            },
            "serviceBusNamespaceName": {
              "type": "string"
            },
            "containerAppsEnvironmentName": {
              "type": "string"
            },
            "containerRegistryName": {
              "type": "string"
            }
          },
          "variables": {
            "copy": [
              {
                "name": "containerAppNames",
                "count": "[length(variables('services'))]",
                "input": "[format('{0}-{1}-{2}', parameters('prefix'), parameters('environmentName'), variables('services')[copyIndex('containerAppNames')].appSuffix)]"
              }
            ],
            "services": [
              {
                "name": "api-gateway",
                "appSuffix": "apigw",
                "external": true,
                "minReplicas": 1
              },
              {
                "name": "orders-service",
                "appSuffix": "orders",
                "external": false,
                "minReplicas": 1
              },
              {
                "name": "inventory-service",
                "appSuffix": "inventory",
                "external": false,
                "minReplicas": 0
              },
              {
                "name": "notifications-service",
                "appSuffix": "notify",
                "external": false,
                "minReplicas": 0
              },
              {
                "name": "portal-web",
                "appSuffix": "portal",
                "external": true,
                "minReplicas": 1
              }
            ],
            "keyVaultSecretsUserRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]",
            "acrPullRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]"
          },
          "resources": [
            {
              "type": "Microsoft.OperationalInsights/workspaces",
              "apiVersion": "2023-09-01",
              "name": "[parameters('logAnalyticsName')]",
              "location": "[parameters('location')]",
              "properties": {
                "sku": {
                  "name": "PerGB2018"
                },
                "retentionInDays": 30
              }
            },
            {
              "type": "Microsoft.Insights/components",
              "apiVersion": "2020-02-02",
              "name": "[parameters('appInsightsName')]",
              "location": "[parameters('location')]",
              "kind": "web",
              "properties": {
                "Application_Type": "web",
                "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName'))]"
              },
              "dependsOn": [
                "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName'))]"
              ]
            },
            {
              "type": "Microsoft.KeyVault/vaults",
              "apiVersion": "2023-07-01",
              "name": "[parameters('keyVaultName')]",
              "location": "[parameters('location')]",
              "properties": {
                "tenantId": "[subscription().tenantId]",
                "sku": {
                  "family": "A",
                  "name": "standard"
                },
                "enableRbacAuthorization": true,
                "enabledForDeployment": false,
                "enabledForTemplateDeployment": false,
                "enabledForDiskEncryption": false,
                "softDeleteRetentionInDays": 90,
                "enableSoftDelete": true,
                "publicNetworkAccess": "Enabled"
              }
            },
            {
              "type": "Microsoft.ServiceBus/namespaces",
              "apiVersion": "2023-01-01-preview",
              "name": "[parameters('serviceBusNamespaceName')]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "Standard",
                "tier": "Standard"
              },
              "properties": {
                "publicNetworkAccess": "Enabled"
              }
            },
            {
              "type": "Microsoft.ContainerRegistry/registries",
              "apiVersion": "2023-07-01",
              "name": "[parameters('containerRegistryName')]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "Basic"
              },
              "properties": {
                "adminUserEnabled": false
              }
            },
            {
              "type": "Microsoft.App/managedEnvironments",
              "apiVersion": "2024-03-01",
              "name": "[parameters('containerAppsEnvironmentName')]",
              "location": "[parameters('location')]",
              "properties": {
                "appLogsConfiguration": {
                  "destination": "log-analytics",
                  "logAnalyticsConfiguration": {
                    "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName')), '2023-09-01').customerId]",
                    "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName')), '2023-09-01').primarySharedKey]"
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName'))]"
              ]
            },
            {
              "copy": {
                "name": "containerApps",
                "count": "[length(variables('services'))]"
              },
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2024-03-01",
              "name": "[variables('containerAppNames')[copyIndex()]]",
              "location": "[parameters('location')]",
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "environmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
                "configuration": {
                  "ingress": {
                    "external": "[variables('services')[copyIndex()].external]",
                    "targetPort": 3000,
                    "transport": "auto"
                  },
                  "activeRevisionsMode": "Single"
                },
                "template": {
                  "containers": [
                    {
                      "name": "[variables('services')[copyIndex()].name]",
                      "image": "mcr.microsoft.com/azuredocs/containerapps-helloworld:latest",
                      "env": [
                        {
                          "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                          "value": "[reference(resourceId('Microsoft.Insights/components', parameters('appInsightsName')), '2020-02-02').ConnectionString]"
                        },
                        {
                          "name": "SERVICEBUS_NAMESPACE",
                          "value": "[parameters('serviceBusNamespaceName')]"
                        },
                        {
                          "name": "KEYVAULT_URI",
                          "value": "[reference(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), '2023-07-01').vaultUri]"
                        },
                        {
                          "name": "ENVIRONMENT_NAME",
                          "value": "[parameters('environmentName')]"
                        }
                      ],
                      "resources": {
                        "cpu": "[json('0.5')]",
                        "memory": "1Gi"
                      },
                      "probes": [
                        {
                          "type": "Liveness",
                          "httpGet": {
                            "path": "/health",
                            "port": 3000
                          },
                          "initialDelaySeconds": 20,
                          "periodSeconds": 10
                        },
                        {
                          "type": "Readiness",
                          "httpGet": {
                            "path": "/health",
                            "port": 3000
                          },
                          "initialDelaySeconds": 15,
                          "periodSeconds": 10
                        },
                        {
                          "type": "Startup",
                          "httpGet": {
                            "path": "/health",
                            "port": 3000
                          },
                          "initialDelaySeconds": 5,
                          "periodSeconds": 10,
                          "failureThreshold": 18
                        }
                      ]
                    }
                  ],
                  "scale": {
                    "minReplicas": "[variables('services')[copyIndex()].minReplicas]",
                    "maxReplicas": 3
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Insights/components', parameters('appInsightsName'))]",
                "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]",
                "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
                "[resourceId('Microsoft.ServiceBus/namespaces', parameters('serviceBusNamespaceName'))]"
              ]
            },
            {
              "copy": {
                "name": "keyVaultSecretAccess",
                "count": "[length(variables('containerAppNames'))]"
              },
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
              "name": "[guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), variables('containerAppNames')[copyIndex()], 'keyvault-secrets-user')]",
              "properties": {
                "principalId": "[reference(resourceId('Microsoft.App/containerApps', variables('containerAppNames')[copyIndex()]), '2024-03-01', 'full').identity.principalId]",
                "roleDefinitionId": "[variables('keyVaultSecretsUserRoleDefinitionId')]",
                "principalType": "ServicePrincipal"
              },
              "dependsOn": [
                "[resourceId('Microsoft.App/containerApps', variables('containerAppNames')[copyIndex()])]",
                "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
              ]
            },
            {
              "copy": {
                "name": "acrPullRoleAssignments",
                "count": "[length(variables('containerAppNames'))]"
              },
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName'))]",
              "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), variables('containerAppNames')[copyIndex()], 'acrpull')]",
              "properties": {
                "principalId": "[reference(resourceId('Microsoft.App/containerApps', variables('containerAppNames')[copyIndex()]), '2024-03-01', 'full').identity.principalId]",
                "roleDefinitionId": "[variables('acrPullRoleDefinitionId')]",
                "principalType": "ServicePrincipal"
              },
              "dependsOn": [
                "[resourceId('Microsoft.App/containerApps', variables('containerAppNames')[copyIndex()])]",
                "[resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName'))]"
              ]
            }
          ],
          "outputs": {
            "containerAppsEnvironmentId": {
              "type": "string",
              "value": "[resourceId('Microsoft.App/managedEnvironments', parameters('containerAppsEnvironmentName'))]"
            },
            "containerRegistryLoginServer": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), '2023-07-01').loginServer]"
            },
            "containerAppNames": {
              "type": "array",
              "value": "[variables('containerAppNames')]"
            }
          }
        }
      },
      "dependsOn": [
        "[subscriptionResourceId('Microsoft.Resources/resourceGroups', variables('rgName'))]"
      ]
    }
  ],
  "outputs": {
    "resourceGroupName": {
      "type": "string",
      "value": "[variables('rgName')]"
    },
    "containerAppsEnvironmentId": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('rgName')), 'Microsoft.Resources/deployments', 'platform-resources'), '2025-04-01').outputs.containerAppsEnvironmentId.value]"
    },
    "containerRegistryLoginServer": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('rgName')), 'Microsoft.Resources/deployments', 'platform-resources'), '2025-04-01').outputs.containerRegistryLoginServer.value]"
    }
  }
}